<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F11"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/studioTopBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1D"
        android:paddingLeft="4dp"
        android:paddingRight="4dp">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnStudioBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="&#8592;"
            android:textColor="#909098"
            android:textSize="20sp"
            android:background="@android:color/transparent"/>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#2A2A2F"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="6dp"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvStudioTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Studio"
            android:textColor="#EEEEF2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="middle"/>

        <!-- Inject button -->
        <LinearLayout
            android:id="@+id/btnStudioInject"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#1E1A00"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_marginRight="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INJECT"
                android:textColor="#E8C24A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Apply button -->
        <LinearLayout
            android:id="@+id/btnStudioApply"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#001A00"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPLY"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2F"/>

    <!-- Status bar -->
    <TextView
        android:id="@+id/tvStudioStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="28dp"
        android:gravity="center_vertical"
        android:background="#161618"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="Login to Google AI Studio, then tap INJECT to give AI your files."
        android:textColor="#909098"
        android:textSize="11sp"
        android:singleLine="false"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2F"/>

    <!-- WebView takes the rest -->
    <WebView
        android:id="@+id/studioWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
