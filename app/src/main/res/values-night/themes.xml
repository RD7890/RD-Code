<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.RyzixCode" parent="android:Theme.Holo.NoActionBar">
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:statusBarColor">@color/bg_panel</item>
        <item name="android:navigationBarColor">@color/bg_app</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
    </style>

    <style name="Theme.RyzixCode.Splash" parent="Theme.RyzixCode">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

</resources>
